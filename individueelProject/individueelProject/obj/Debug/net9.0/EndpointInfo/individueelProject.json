        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "isEmailConfirmed": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          },
          "twoFactorCode": {
            "type": "string",
            "nullable": true
          },
          "twoFactorRecoveryCode": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Object2D": {
        "required": [
          "postionX",
          "postionY",
          "prefabId",
          "rotationZ",
          "scaleX",
          "scaleY",
          "sortingLayer"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "environmentId": {
            "type": "string",
            "format": "uuid"
          },
          "prefabId": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "postionX": {
            "type": "number",
            "format": "double"
          },
          "postionY": {
            "type": "number",
            "format": "double"
          },
          "scaleX": {
            "type": "number",
            "format": "double"
          },
          "scaleY": {
            "type": "number",
            "format": "double"
          },
          "rotationZ": {
            "type": "number",
            "format": "double"
          },
          "sortingLayer": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "Object2DDTO": {
        "required": [
          "environmentName",
          "postionX",
          "postionY",
          "prefabId",
          "rotationZ",
          "scaleX",
          "scaleY",
          "sortingLayer"
        ],
        "type": "object",
        "properties": {
          "environmentName": {
            "minLength": 1,
            "type": "string"
          },
          "prefabId": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "postionX": {
            "type": "number",
            "format": "double"
          },
          "postionY": {
            "type": "number",
            "format": "double"
          },
          "scaleX": {
            "type": "number",
            "format": "double"
          },
          "scaleY": {
            "type": "number",
            "format": "double"
          },
          "rotationZ": {
            "type": "number",
            "format": "double"
          },
          "sortingLayer": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "RefreshRequest": {
        "required": [
          "refreshToken"
        ],
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "nullable": true
          }
        },
